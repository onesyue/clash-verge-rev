{
  "version": "2.1.4",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "YueTong is a high-performance proxy client built with Tauri 2 and mihomo core, featuring native XBoard panel integration for seamless subscription management.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources"
    ],
    "publisher": "YueTong",
    "externalBin": [
      "sidecar/verge-mihomo",
      "sidecar/verge-mihomo-alpha"
    ],
    "copyright": "GNU General Public License v3.0",
    "category": "Utility",
    "shortDescription": "Proxy client with XBoard panel integration",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3000/",
    "removeUnusedCommands": true
  },
  "productName": "YueTong",
  "identifier": "io.yuetong.app",
  "plugins": {
    "updater": {
      "pubkey": "RWRNZjuHIwyU6rJMhiQbb2WJyNuRUa8+TPoUcdFC/7YXycJIVkrg77Cm",
      "endpoints": [
        "https://github.com/onesyue/clash-verge-rev/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "clash"
        ]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": [
        "desktop-capability",
        "migrated"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  }
}
