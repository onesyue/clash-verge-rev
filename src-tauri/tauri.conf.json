{
  "version": "1.0.1-alpha",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "YueTong is a high-performance proxy client built with Tauri 2 and mihomo core, featuring native XBoard panel integration for seamless subscription management.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources"],
    "publisher": "YueTong",
    "externalBin": ["sidecar/verge-mihomo", "sidecar/verge-mihomo-alpha"],
    "copyright": "GNU General Public License v3.0",
    "category": "Utility",
    "shortDescription": "Proxy client with XBoard panel integration",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3000/",
    "removeUnusedCommands": true
  },
  "productName": "YueTong",
  "identifier": "io.yuetong.app",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNGMDFGMjMyMUIzNTRDQjQKUldTMFREVWJNdklCUHloRjY3aVZSbFZsSW55Z2tYeEUzK1JvMkZCbGF4TkZTMndoU3hVQ0lPcy8K",
      "endpoints": [
        "https://github.com/onesyue/clash-verge-rev/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["clash"]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": ["desktop-capability", "migrated"],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  }
}
